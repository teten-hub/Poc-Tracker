# Threat Intelligence API Keys for IP Analyzer
# Copy this file to .env.local and fill in the values below.

# VirusTotal API Key (https://www.virustotal.com/)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AlienVault OTX API Key (https://otx.alienvault.com/)
OTX_API_KEY=your_otx_api_key_here

# AbuseIPDB API Key (https://www.abuseipdb.com/)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
